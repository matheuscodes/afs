{
  "compilerOptions": {
    "jsx": "react",
    "allowJs": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "lib": [
      "es2019",
      "dom"
    ]
  },
  "include": [
    "src/**/*"
  ]
}
